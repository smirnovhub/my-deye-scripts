#!/usr/bin/python3 -u

# The -u option in Python runs the interpreter in unbuffered mode.
# That means:
# stdout and stderr are written immediately (no buffering).
# You don’t have to wait for the buffer to fill or for the program to
# exit before print() outputs appear.
# Equivalent to setting the environment variable PYTHONUNBUFFERED=1.
# This is especially useful when running Python scripts under systemd,
# Docker, or when piping output to journalctl, because you want log
# messages from print() to show up in real time.

import os
import sys
import time
import html
import traceback

from pathlib import Path

current_path = Path(__file__).parent.resolve()
modules_path = (current_path / '../modules').resolve()

os.chdir(current_path)
sys.path.append(str(modules_path))

from common_modules import import_dirs

import_dirs(current_path, ['src', '../deye/src', '../common'])

import telebot

# Simple and safe way for HTML parse_mode
def escape_html(text: str) -> str:
  # This replaces &, <, and > with &amp;, &lt;, and &gt;
  return html.escape(text)

try:
  from mytelebot import MyTelebot
  from env_utils import EnvUtils
  from common_utils import CommonUtils
  from testable_telebot import TestableTelebot
  from telebot_credentials import TelebotCredentials
  from telebot_send_message import send_private_telegram_message
  
  if EnvUtils.is_tests_on():
    token = EnvUtils.get_telegram_bot_api_test_token()
    bot = TestableTelebot(token)
    mybot = MyTelebot(bot)
    mybot.run_tests()
    sys.exit(0)
  
  send_private_telegram_message(f'{CommonUtils.clock_face_two_oclock_emoji} Starting telebot...')
  bot = telebot.TeleBot(TelebotCredentials.BOT_API_TOKEN)
  mybot = MyTelebot(bot)
  bot.infinity_polling()
except Exception as e:
  stack_trace = escape_html(traceback.format_exc()[-2048:])
  send_private_telegram_message(f"{CommonUtils.large_red_circle_emoji} "
                                f"Telebot unexpectedly stopped working:\n"
                                f"<code>{stack_trace}</code>")
  time.sleep(30)
  raise
