{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "format": "[%(asctime)s.%(msecs)03d] %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "file": {
      "()": "src.hourly_overwrite_file_handler.HourlyOverwriteFileHandler",
      "directory": "data/deyecache",
      "log_file_template": "deyecache-{0}.log",
      "formatter": "default"
    },
    "console": {
      "class": "logging.StreamHandler",
      "formatter": "default",
      "stream": "ext://sys.stdout"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["file", "console"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.error": {
      "handlers": ["file", "console"],
      "level": "INFO",
      "propagate": false
    },
    "uvicorn.access": {
      "handlers": ["file", "console"],
      "level": "INFO",
      "propagate": false
    }
  }
}
