# Main branch for features
APP_BRANCH=master

# Global limits for all containers
GLOBAL_PIDS_LIMIT=128
GLOBAL_MEMORY_LIMIT=128M

# Telebot settings
DEYE_TELEBOT_PIDS_LIMIT=128
DEYE_TELEBOT_MEMORY_LIMIT=256M

# Deye loggers settings
DEYE_MASTER_LOGGER_HOST=192.168.0.77
DEYE_MASTER_LOGGER_SERIAL=1234567
DEYE_MASTER_LOGGER_PROXY_HOST=deye-proxy

# Deye cache settings
REMOTE_STORAGE_SERVER_URL=http://deye-storage

# Deye Web settings
DEYE_WEB_HTTP_MAPPING_PORT=380
DEYE_WEB_HTTPS_MAPPING_PORT=3443
DEYE_WEB_BACK_SERVER_URL=http://deye-back-server

# Telegram settings
TELEGRAM_ADMIN_USER_ID=1234567
TELEGRAM_BOT_API_TOKEN="YOUR BOT TOKEN"
TELEGRAM_BOT_API_TEST_TOKEN="YOUR BOT TOKEN TO RUN TESTS"
TELEGRAM_PRIVATE_CHAT_ID=1234567
TELEGRAM_PUBLIC_CHAT_ID="-1234567"

# Set GPS coordinates for sunrise/sunset calculation
DEYE_GPS_LATITUDE=50.45
DEYE_GPS_LONGITUDE=30.52

# Set energy costs
DEYE_PV_ENERGY_COSTS_JSON='{"0": 4.32}'
DEYE_GRID_PURCHASED_ENERGY_COSTS_JSON='{"0": 4.32}'
DEYE_GRID_FEED_IN_ENERGY_COSTS_JSON='{"0": 4.32}'
DEYE_GEN_ENERGY_COSTS_JSON='{"0": 4.32}'

# Set currency code for energy costs
DEYE_ENERGY_COST_CURRENCY_CODE=USD
