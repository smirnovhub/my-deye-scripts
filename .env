# Main branch for features
APP_BRANCH=develop

#####################
### USER SETTINGS ###
#####################

# Deye loggers settings
DEYE_MASTER_LOGGER_HOST=192.168.0.77
DEYE_MASTER_LOGGER_SERIAL=1234567

# Example configuration for slave.
# You can add up to 15 slaves
# (see docker-compose.yml for details)
#DEYE_SLAVE1_LOGGER_HOST=192.168.0.79
#DEYE_SLAVE1_LOGGER_SERIAL=1234567

# Telegram settings
TELEGRAM_ADMIN_USER_ID=1234567
TELEGRAM_BOT_API_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_BOT_API_TEST_TOKEN=YOUR_BOT_TOKEN_TO_RUN_TESTS
TELEGRAM_PRIVATE_CHAT_ID=1234567
TELEGRAM_PUBLIC_CHAT_ID=-1234567

#######################
### SYSTEM SETTINGS ###
#######################

# Global limits for all containers
GLOBAL_PIDS_LIMIT=128
GLOBAL_MEMORY_LIMIT=128M

# Telebot limits settings
DEYE_TELEBOT_PIDS_LIMIT=128
DEYE_TELEBOT_MEMORY_LIMIT=256M

# Deye Web settings
DEYE_WEB_HTTP_MAPPING_PORT=380
DEYE_WEB_HTTPS_MAPPING_PORT=3443

# Log observer settings
LOG_OBSERVER_HTTP_MAPPING_PORT=480
LOG_OBSERVER_HTTPS_MAPPING_PORT=4443

######################
### OTHER SETTINGS ###
######################

# GPS coordinates for sunrise/sunset calculation
# Valid range for latitude: [-90, 90]
# Valid range for longitude: [-180, 180]
DEYE_GPS_LATITUDE=50.45
DEYE_GPS_LONGITUDE=30.52

# Energy costs for energy cost calculation
# All JSON must be a single-line string!
# JSON example:
# {
#   "0": 4.32, # apply price 4.32 from start
#   "200": 4.5, # apply price 4.5 after 200 kWh
#   "300": 5.7 # apply price 5.7 after 300 kWh
# }
DEYE_PV_ENERGY_COSTS_JSON='{"0": 4.32}'
DEYE_GRID_PURCHASED_ENERGY_COSTS_JSON='{"0": 4.32}'
DEYE_GRID_FEED_IN_ENERGY_COSTS_JSON='{"0": 4.32}'
DEYE_GEN_ENERGY_COSTS_JSON='{"0": 4.32}'

# Currency code for energy costs
DEYE_ENERGY_COST_CURRENCY_CODE=USD

DATA_COLLECTOR_COLLECTING_INTERVAL=180
